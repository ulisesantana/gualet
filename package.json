{
  "name": "gualet",
  "version": "1.0.0",
  "workspaces": [
    "backend",
    "frontend",
    "e2e",
    "core"
  ],
  "description": "Gualet is an app designed to help you manage your finances easily.",
  "main": "backend/dist/main.js",
  "scripts": {
    "dev": "run-p dev:core dev:backend dev:frontend",
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "dev:core": "npm run dev -w core",
    "build": "npm run build -w core && npm run build -w frontend && cp -r ./frontend/dist ./backend/dist/public",
    "test": "npm run test -ws",
    "test:backend": "npm run test -w backend",
    "test:backend:cov": "npm run test:cov -w backend",
    "test:frontend": "npm run test -w frontend",
    "test:frontend:cov": "npm run test:cov -w frontend",
    "test:e2e": "npm run test -w e2e",
    "test:e2e:ui": "npm run test:ui -w e2e",
    "typecheck": "npm run typecheck -w core && npm run typecheck -w backend && npm run typecheck -w frontend && npm run typecheck -w e2e",
    "typecheck:core": "npm run typecheck -w core",
    "typecheck:backend": "npm run typecheck -w backend",
    "typecheck:frontend": "npm run typecheck -w frontend",
    "typecheck:e2e": "npm run typecheck -w e2e",
    "db:dev:up": "docker compose -f docker-compose.yaml up -d",
    "db:dev:down": "docker compose -f docker-compose.yaml down",
    "dependencies:restart": "rm -rf **/node_modules && npm install"
  },
  "author": "Ulises Santana Suárez <ulisesantana@gmail.com>",
  "license": "ISC",
  "packageManager": "npm@10.9.2",
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "npm-run-all": "4.1.5"
  },
  "dependencies": {
    "@types/bcrypt": "5.0.2",
    "bcrypt": "5.1.1",
    "dotenv": "16.5.0",
    "playwright": "^1.56.1",
    "uuid": "11.1.0"
  }
}
