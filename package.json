{
  "name": "gualet",
  "version": "1.0.0",
  "workspaces": [
    "packages/backend",
    "packages/frontend",
    "packages/e2e",
    "packages/shared"
  ],
  "description": "Gualet is an app designed to help you manage your finances easily.",
  "main": "packages/backend/dist/main.js",
  "scripts": {
    "dev": "run-p dev:shared dev:backend dev:frontend",
    "dev:backend": "npm run dev -w packages/backend",
    "dev:frontend": "npm run dev -w packages/frontend",
    "dev:shared": "npm run dev -w packages/shared",
    "build": "npm run build -w packages/shared && npm run build -w frontend && cp -r ./packages/frontend/dist ./packages/backend/dist/public",
    "test": "npm run test -ws",
    "test:backend": "npm run test -w packages/backend",
    "test:backend:cov": "npm run test:cov -w packages/backend",
    "test:frontend": "npm run test -w packages/frontend",
    "test:frontend:cov": "npm run test:cov -w packages/frontend",
    "test:e2e": "npm run test -w packages/e2e",
    "test:e2e:ui": "npm run test:ui -w packages/e2e",
    "typecheck": "npm run typecheck -w packages/shared && npm run typecheck -w packages/backend && npm run typecheck -w packages/frontend && npm run typecheck -w packages/e2e",
    "typecheck:shared": "npm run typecheck -w packages/shared",
    "typecheck:backend": "npm run typecheck -w packages/backend",
    "typecheck:frontend": "npm run typecheck -w packages/frontend",
    "typecheck:e2e": "npm run typecheck -w packages/e2e",
    "db:dev:up": "docker compose -f docker-compose.yaml up -d",
    "db:dev:down": "docker compose -f docker-compose.yaml down",
    "db:dev:clean": "npm run db:clean -w packages/backend",
    "db:dev:seed": "npm run db:seed -w packages/backend",
    "dependencies:restart": "rm -rf node_modules package-lock.json packages/*/node_modules packages/*/package-lock.json && npm install"
  },
  "author": "Ulises Santana Suárez <ulisesantana@gmail.com>",
  "license": "ISC",
  "packageManager": "npm@10.9.2",
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "npm-run-all": "4.1.5",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@types/bcrypt": "5.0.2",
    "bcrypt": "5.1.1",
    "dotenv": "16.5.0",
    "playwright": "^1.56.1",
    "uuid": "11.1.0"
  }
}
