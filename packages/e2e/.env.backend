# Backend configuration for E2E tests
NODE_ENV=test
PORT=5060

# JWT
JWT_SECRET=e2e_test_secret_key_please_change_in_production
JWT_EXPIRES_IN=7d

# Cookie
COOKIE_SECRET=e2e_test_cookie_secret_key_please_change_in_production

# PostgreSQL (E2E Test Database)
POSTGRES_USER=test
POSTGRES_PASSWORD=test
POSTGRES_DB=test_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# CORS
CORS_ORIGIN=http://localhost:3010

