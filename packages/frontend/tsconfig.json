{
  "compilerOptions": {
    "target": "es5",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"],
      "@features/*": ["src/features/*"],
      "@common/*": ["src/features/common/*"],
      "@common/infrastructure": ["src/features/common/infrastructure"],
      "@common/application/use-case": ["src/features/common/application/use-case"],
      "@common/domain/types": ["src/features/common/domain/types"],
      "@common/infrastructure/http": ["src/features/common/infrastructure/http"],
      "@common/ui/components": ["src/features/common/ui/components"],
      "@infrastructure/types": ["src/features/common/infrastructure/types"],
      "@infrastructure/repositories": ["src/features/common/infrastructure"],
      "@infrastructure/ui/App/App": ["src/features/common/ui/App/App"],
      "@domain/models": ["src/features/common/domain"],
      "@auth": ["src/features/auth"],
      "@auth/*": ["src/features/auth/*"],
      "@auth/application": ["src/features/auth/application"],
      "@categories": ["src/features/categories"],
      "@categories/*": ["src/features/categories/*"],
      "@categories/application": ["src/features/categories/application"],
      "@payment-methods": ["src/features/payment-methods"],
      "@payment-methods/*": ["src/features/payment-methods/*"],
      "@payment-methods/application": ["src/features/payment-methods/application"],
      "@transactions": ["src/features/transactions"],
      "@transactions/*": ["src/features/transactions/*"],
      "@transactions/application": ["src/features/transactions/application"],
      "@reports": ["src/features/reports"],
      "@reports/*": ["src/features/reports/*"],
      "@reports/domain": ["src/features/reports/domain"],
      "@reports/application": ["src/features/reports/application"],
      "@settings": ["src/features/settings"],
      "@settings/*": ["src/features/settings/*"],
      "@settings/application": ["src/features/settings/application"],
      "@test/*": ["test/*"]
    },
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
  },
  "references": [
    {
      "path": "../shared"
    },
  ],
  "include": [
    "src",
    "test",
    ".storybook"
  ],
  "exclude": [
    "**/node_modules",
    "dist",
    "build"
  ]
}
