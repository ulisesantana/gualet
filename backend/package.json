{
  "name": "@gualet/backend",
  "version": "0.0.1",
  "description": "",
  "author": "Ulises Santana Suárez <ulisesantana@gmail.com>",
  "homepage": "https://ulisesantana.github.io/gualet",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "dev": "npm run start:dev",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "migration:generate": "npx typeorm-ts-node-commonjs migration:generate src/migrations/InitSchema -d src/db/data-source.ts",
    "migration:run": "npx typeorm-ts-node-commonjs migration:run -d src/db/data-source.ts",
    "migration:revert": "npx typeorm-ts-node-commonjs migration:revert -d src/db/data-source.ts",
    "migration:export-sql": "NO_COLOR=1 npx typeorm-ts-node-commonjs schema:log -d src/db/data-source.ts > src/db/init.sql"
  },
  "dependencies": {
    "@nestjs/common": "11.0.2",
    "@nestjs/config": "4.0.1",
    "@nestjs/core": "11.0.2",
    "@nestjs/jwt": "11.0.0",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.0.2",
    "@nestjs/serve-static": "5.0.3",
    "@nestjs/swagger": "11.0.7",
    "@nestjs/typeorm": "11.0.0",
    "@types/cookie-parser": "1.4.8",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "cookie-parser": "1.4.7",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "pg": "8.14.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "typeorm": "0.3.22",
    "uuid": "11.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.2.0",
    "@eslint/js": "9.18.0",
    "@nestjs/cli": "11.0.0",
    "@nestjs/schematics": "11.0.0",
    "@nestjs/testing": "11.0.2",
    "@swc/cli": "0.6.0",
    "@swc/core": "1.10.7",
    "@types/express": "5.0.0",
    "@types/jest": "29.5.14",
    "@types/node": "22.10.7",
    "@types/passport-jwt": "4.0.1",
    "@types/supertest": "6.0.2",
    "dotenv": "16.4.7",
    "eslint": "9.18.0",
    "eslint-config-prettier": "10.0.1",
    "eslint-plugin-prettier": "5.2.2",
    "globals": "16.0.0",
    "jest": "29.7.0",
    "prettier": "3.4.2",
    "source-map-support": "0.5.21",
    "supertest": "7.0.0",
    "ts-jest": "29.2.5",
    "ts-loader": "9.5.2",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.7.3",
    "typescript-eslint": "8.20.0"
  },
  "packageManager": "npm@10.9.2",
  "typeorm": {
    "cli": {
      "migrationsDir": "src/migrations"
    }
  }
}
